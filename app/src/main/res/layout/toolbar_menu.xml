<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/toolbarMenuLayout"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_toolbar_menu_layout"
    android:clipToOutline="true"
    android:gravity="end"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingTop="10dp"
    android:paddingEnd="10dp"
    android:paddingBottom="16dp"
    android:visibility="gone">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/toolbarMenuList"
        android:layout_width="360dp"
        android:layout_height="216dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingEnd="8dp" />

    <LinearLayout
        android:id="@+id/toolbarMenuActionSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end|center_vertical"
        android:orientation="horizontal"
        android:paddingTop="2dp">

        <ImageButton
            android:id="@+id/btnExit"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="45dp"
            android:background="@android:color/transparent"
            android:contentDescription="Exit"
            android:src="@drawable/ic_power" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="45dp"
            android:background="@android:color/transparent"
            android:contentDescription="Settings"
            android:src="@drawable/ic_hexagon" />

        <ImageButton
            android:id="@+id/btnCloseMenu"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="45dp"
            android:layout_marginEnd="8dp"
            android:background="@android:color/transparent"
            android:contentDescription="Close"
            android:src="@drawable/ic_chevron_down" />
    </LinearLayout>
</LinearLayout>
