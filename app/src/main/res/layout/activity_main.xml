<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@string/app_name"
        android:src="@drawable/ic_launcher_foreground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/toolbarMenuLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="#E61E1E1E"
        android:orientation="horizontal"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <GridLayout
            android:id="@+id/toolbarMenuMainSection"
            android:layout_width="0dp"
            android:layout_height="216dp"
            android:layout_weight="1"
            android:columnCount="5"
            android:rowCount="2"
            android:useDefaultMargins="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="4dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_menu_placeholder" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="4dp"><ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_menu_placeholder" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" /></LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="4dp"><ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_menu_placeholder" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" /></LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="4dp"><ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_menu_placeholder" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" /></LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="4dp"><ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_menu_placeholder" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" /></LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="4dp"><ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_menu_placeholder" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" /></LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="4dp"><ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_menu_placeholder" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" /></LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="4dp"><ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_menu_placeholder" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" /></LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="4dp"><ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_menu_placeholder" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" /></LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="4dp"><ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_menu_placeholder" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" /></LinearLayout>
        </GridLayout>

        <LinearLayout
            android:id="@+id/toolbarMenuActionSection"
            android:layout_width="64dp"
            android:layout_height="194dp"
            android:layout_marginStart="8dp"
            android:gravity="space_evenly"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnExit"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="Exit"
                android:src="@drawable/ic_power" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="Settings"
                android:src="@drawable/ic_hexagon" />

            <ImageButton
                android:id="@+id/btnCloseMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="Close"
                android:src="@drawable/ic_chevron_down" />
        </LinearLayout>
    </LinearLayout>

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:background="#CC000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/toolbarMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="12dp"
            android:background="@android:color/transparent"
            android:contentDescription="Menu"
            android:src="@drawable/ic_menu_3line" />
    </androidx.appcompat.widget.Toolbar>

</androidx.constraintlayout.widget.ConstraintLayout>
